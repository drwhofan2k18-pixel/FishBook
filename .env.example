# FishBook Environment Variables
# Copy this file to .env and fill in your values
# All EXPO_PUBLIC_ vars are exposed to the client bundle

# Supabase (required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# OpenWeatherMap API Key (optional — enables weather widget + bite forecast)
# Get a free key at: https://openweathermap.org/api
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# TFLite Model URL (optional — enables on-device fish identification)
# Host your .tflite model on Supabase Storage or any CDN
EXPO_PUBLIC_TFLITE_MODEL_URL=

# Sentry DSN (optional — enables crash reporting)
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=
